# Internal tools access gate (/internal/*).
# Sign-in credentials now live in Supabase (the internal_users table, seeded by the
# internal_auth migration) — not in these env vars. Default seeded login: admin / ByteFlow!2026
# (change it after first sign-in).
#
# Signing secret for the internal-tools session cookie. Set to any long random string in
# each environment. If unset, the signing key falls back to deriving from the legacy
# INTERNAL_TOOLS_USERNAME/PASSWORD vars below, so existing deployments keep working.
INTERNAL_TOOLS_SESSION_SECRET=
# Legacy: only used as the session-signing fallback when INTERNAL_TOOLS_SESSION_SECRET is
# unset. No longer checked at login. Safe to remove once a session secret is set everywhere.
INTERNAL_TOOLS_USERNAME=
INTERNAL_TOOLS_PASSWORD=

# Supabase project backing the stateful internal tools (CRM + budgets) — see
# SUPABASE-SETUP.md. Server-only: read exclusively by the API routes; the browser never
# talks to Supabase and no NEXT_PUBLIC_SUPABASE_* variable may ever exist here.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Existing site vars (already configured in deployment; listed here for completeness):
# CONTENTFUL_SPACE_ID=
# CONTENTFUL_ACCESS_TOKEN=
# CONTENTFUL_PERSONAL_ACCESS_TOKEN=  (only for npm run generate:types)
# SENDGRID_API_KEY=                  (contact form)
# SENDGRID_FROM_EMAIL=
# SENDGRID_TEMPLATE_ID=
# GOOGLE_SHEET_WEBHOOK_URL=
