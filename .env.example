# Internal tools access gate (/internal/proposal-tool).
# Set real values in the deployment environment (e.g. Vercel project env vars) and in
# .env.local for local dev. Never commit real values. If either is unset, the gate
# fails safe: nobody can log in and no session validates.
INTERNAL_TOOLS_USERNAME=
INTERNAL_TOOLS_PASSWORD=

# Existing site vars (already configured in deployment; listed here for completeness):
# CONTENTFUL_SPACE_ID=
# CONTENTFUL_ACCESS_TOKEN=
# CONTENTFUL_PERSONAL_ACCESS_TOKEN=  (only for npm run generate:types)
# SENDGRID_API_KEY=                  (contact form)
# SENDGRID_FROM_EMAIL=
# SENDGRID_TEMPLATE_ID=
# GOOGLE_SHEET_WEBHOOK_URL=
