# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/Contentful-data

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
# docker-compose secrets (copied from .env.docker.example)
.env.docker

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# env files with credentials
*.envs
sendgrid.env

# supabase local project. Config and local state stay out of the repo, but MIGRATIONS are
# tracked: they're the schema the app's code depends on, they contain no secrets, and code
# that needs a table is useless on a machine that can't create it. (Previously the whole
# directory was ignored, which meant every migration lived on exactly one laptop.)
supabase/*
!supabase/migrations/
supabase/migrations/*
!supabase/migrations/*.sql

# internal working docs (handoffs, specs, LLM prompts) — local only
docs/
BYTEFLOW-MEGA-PROMPT-*.md
