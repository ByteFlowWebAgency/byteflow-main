# ── Docker Compose secrets ───────────────────────────────────────────────────
# Copy this file to .env.docker, fill in the values, then run:
#   docker compose --env-file .env.docker up --build
# .env.docker is gitignored — never commit real values.
#
# (Most of these are the same values you already have in .env.local.)

# Shared key between the web app and the audit service (any long random string).
# The web app sends it as X-API-Key; the audit service checks it.
AUDIT_API_KEY=change-me-to-a-long-random-string

# Contentful — REQUIRED. The web BUILD renders the marketing pages and case
# studies from Contentful and fails without these. Read-only delivery creds.
CONTENTFUL_SPACE_ID=
CONTENTFUL_ACCESS_TOKEN=

# Supabase — REQUIRED for the /internal tools (auth, CRM, budgets, documents).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth — optional (Calendar / meetings on the internal hub).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PROJECT_ID=

# SendGrid — optional (marketing contact form).
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=
# SENDGRID_TEMPLATE_ID=

# Audit-service CORS origin — optional (defaults to http://localhost:3000). The
# web app calls the audit service server-side, so this rarely matters.
# ALLOWED_ORIGIN=http://localhost:3000
