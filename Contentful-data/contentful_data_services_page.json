                "eyebrow": "02",
                "title": "Custom Development",
                "tagline": "Bespoke solutions for unique challenges",
                "description": "Off-the-shelf software forces you to compromise. We build custom applications tailored to your exact specifications — from complex internal dashboards to customer-facing platforms. Clean, performant, and secure code, delivered through an agile methodology.",
                "bullets": [
                  "Full-Stack Web Development",
                  "Progressive Web Apps",
                  "Internal Tooling",
                  "MVP Development"
                ]
